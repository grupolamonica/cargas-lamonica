# ── Coletor Nestlé (Projeto Galileu adaptado) ──────────────────────────────────
# Copie para .env (NÃO versionar) OU injete via backend.env no docker-compose.

# Galileo (TMS da Nestlé) — ORIGEM. Obrigatórios p/ o coletor rodar.
GALILEU_URL=
GALILEU_USER=
GALILEU_PASSWORD=

# Supabase de DESTINO = projeto do Cargas Lamônica (onde a Programação lê).
# Se não setar, cai para SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY do backend.
NESTLE_SUPABASE_URL=
NESTLE_SUPABASE_SERVICE_ROLE_KEY=

# Cadência do loop de coleta, em segundos (default 60).
NESTLE_COLETA_INTERVAL_SEC=60
