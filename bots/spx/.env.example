# --- Autenticacao ---
# Caminho do arquivo JSON exportado do Chrome (Cookie Editor / EditThisCookie)
SPX_COOKIE_FILE=config/spx_cookies.json

# --- Identificacao do cliente HTTP (sao os headers que o portal manda) ---
SPX_BASE_URL=https://logistics.myagencyservice.com.br
SPX_APP=ssc-spx-agency
# device-id eh 32-char hex; pegar do localStorage["device-id"] no portal logado
SPX_DEVICE_ID=
# version string longa (250+ chars) — copiar do header "version" de uma requisicao do portal
SPX_VERSION=

# --- Contexto da agencia ---
SPX_AGENCY_ID=297

# --- Sidecar FastAPI ---
SPX_SIDECAR_HOST=127.0.0.1
SPX_SIDECAR_PORT=8766

# --- Logs ---
SPX_LOG_LEVEL=INFO
SPX_LOG_DIR=logs
