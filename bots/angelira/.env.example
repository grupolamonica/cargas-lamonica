# =============================================================================
# .env.example — angelira-robo (API-only, sem Selenium)
# Copie para .env e preencha. NUNCA committe .env.
# =============================================================================

# --- Credenciais do portal AngelLira (obrigatorias) -------------------------
ANGELIRA_API_USERNAME=USUARIO.PORTAL
ANGELIRA_API_PASSWORD=senha-portal

# ID numerico da empresa logada (defaults para 876943 = GRIFFI). Troque pelo da
# sua empresa se for diferente.
ANGELIRA_EMPRESA_ID=876943

# --- Endpoints (raramente precisa mudar) ------------------------------------
ANGELIRA_AUTH_BASE=https://auth.angellira.com.br
ANGELIRA_API_BASE=https://api.angellira.com.br/profile

# --- Sidecar FastAPI --------------------------------------------------------
HOST=127.0.0.1
PORT=8765

# CORS origins (csv). Default cobre painel rodando em 5010 e o proprio sidecar.
CORS_ORIGINS=http://localhost:5010,http://127.0.0.1:5010,http://localhost:8765,http://127.0.0.1:8765

# --- Pre-check ---------------------------------------------------------------
# Janela (em dias) para buscar cadastros existentes na API.
ANGELIRA_PRECHECK_DIAS=365
