# =============================================================================
# .env.example — unificada-robo (API-only)
# Copie para .env e preencha.
# =============================================================================

# --- Credenciais do portal AngelLira (obrigatorias) -------------------------
ANGELIRA_API_USERNAME=USUARIO.PORTAL
ANGELIRA_API_PASSWORD=senha-portal
ANGELIRA_COMPANY_ID=876943

# --- Sidecar FastAPI --------------------------------------------------------
UNIFICADA_HOST=127.0.0.1
UNIFICADA_PORT=8001

# --- Logs --------------------------------------------------------------------
UNIFICADA_LOG_LEVEL=INFO
UNIFICADA_LOG_DIR=logs

# --- Logo opcional para o PDF (caminho absoluto pro arquivo SVG) ------------
# Por padrao, busca em ../static/img/angellira-logo.svg
# UNIFICADA_LOGO_PATH=
