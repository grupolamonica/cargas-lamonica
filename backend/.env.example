# backend/.env.example
# Runtime environment variables for the Lamonica Cargas backend.
#
# Production (Docker):
#   Copy this file to `backend.env` in the workspace root (next to docker-compose.yml).
#   docker-compose.yml loads it via `env_file: backend.env`.
#   WARNING: backend.env is gitignored. Never commit real secrets.
#
# Local dev (without Docker):
#   Copy to `backend/.env` (or `backend/.env.local`).
#   load-env.js loads these automatically on startup.

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — Server will fail to start without these.
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL connection string (direct Supabase Postgres, not REST API).
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Includes SSL by default via ?sslmode=require in the URL.
# REQUIRED
SUPABASE_DB_URL=

# Supabase project REST/Auth API URL.
# Format: https://<project-ref>.supabase.co
# REQUIRED
SUPABASE_URL=

# Supabase service role key — full admin access, bypass RLS.
# Found in: Supabase Dashboard → Project Settings → API → service_role (secret)
# WARNING: Keep secret. Never expose in frontend bundle.
# REQUIRED
SUPABASE_SERVICE_ROLE_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Server starts without these; features degrade gracefully.
# ═══════════════════════════════════════════════════════════════════════════════

# HTTP server port. Default: 3001
PORT=3001

# Allowed CORS origins (comma-separated). Fail-closed: empty = no CORS headers set.
# Set to VPS IP for smoke testing before domain is available.
# REPLACE WITH DOMAIN when available (e.g., https://yourdomain.com)
# Example with multiple origins: http://76.13.169.177,https://yourdomain.com
ALLOWED_ORIGINS=http://76.13.169.177

# Trust reverse proxy headers (X-Forwarded-For, X-Forwarded-Proto).
# Set "true" when running behind Traefik or any trusted reverse proxy.
# OPTIONAL — default: false
TRUST_PROXY_HEADERS=true

# Custom header name for extracting the real client IP (e.g., CF-Connecting-IP for Cloudflare).
# If empty, falls back to X-Forwarded-For when TRUST_PROXY_HEADERS=true.
# OPTIONAL
TRUSTED_CLIENT_IP_HEADER=

# ═══════════════════════════════════════════════════════════════════════════════
# INTEGRATIONS — Required only if the corresponding feature is used in production.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Angellira (CPF / vehicle plate validation) ────────────────────────────────
# If not set, the integration is skipped (UNAVAILABLE) — no hard failure.
ANGELLIRA_USER=
ANGELLIRA_PASSWORD=
ANGELLIRA_EMPRESA_ID=

# Angellira circuit breaker and cache tuning (optional — defaults shown)
# ANGELLIRA_TIMEOUT_MS=30000
# ANGELLIRA_CACHE_TTL_SECONDS=300
# ANGELLIRA_TOKEN_CACHE_TTL_SECONDS=1200
# ANGELLIRA_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# ANGELLIRA_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# ── Auto-aprovação por vigência no Angellira ─────────────────────────────────
# Aprova (só muda o status p/ 'aprovado') os cadastros PENDENTES cujo motorista
# está vigente no Angellira. O interruptor de runtime fica no banco
# (app_settings.auto_approve_angellira.enabled) e é ligado/desligado pelo portal;
# vem DESLIGADO por padrão. As vars abaixo controlam só o JOB periódico:
#   AUTO_APPROVE_ANGELLIRA_JOB=false        # kill-switch de infra: nem registra o timer
#   AUTO_APPROVE_ANGELLIRA_INTERVAL_MIN=15  # intervalo entre ciclos do job (min)
#   AUTO_APPROVE_ANGELLIRA_BATCH=25         # CPFs consultados por ciclo

# ── Torre de Controle (dossiê/ranking do motorista por CPF) ──────────────────
# API server-to-server da Torre: GET /api/integrations/drivers/:cpf.
# TORRE_API_KEY = INTEGRATION_API_KEY do torre-backend (mesma VPS).
# If not set, GET /api/operator/cadastros/:id/torre returns 503 (TorreNotConfigured).
TORRE_API_KEY=
# TORRE_API_BASE_URL=https://torre.grupolamonica.com
# TORRE_TIMEOUT_MS=15000
# TORRE_CACHE_TTL_SECONDS=60
# TORRE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# TORRE_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# ── BRK (Brasil Risk — consulta read-only de aptidao do conjunto) ─────────────
# Cliente HTTP de um robo BRK que roda noutra maquina. Se nao configurado, a
# consulta e pulada (UNAVAILABLE) — sem falha. O SYNC e gated por feature-flag
# DESLIGADA por padrao: so persiste no driver_profiles quando BRK_SYNC_ENABLED=1.
# BRK_BASE_URL=
# BRK_API_KEY=
# BRK_SYNC_ENABLED=0
# BRK_TIMEOUT_MS=40000
# BRK_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# BRK_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# ── SPX (Shopee Express — situacao read-only do motorista) ────────────────────
# Usa o mesmo sidecar SPX de cadastro (SPX_BOT_BASE_URL). O SYNC de SITUACAO
# (ativo/inativo/outra agencia/...) para o badge do operador e gated por feature-
# flag DESLIGADA por padrao: so persiste em driver_profiles.spx_vigency_* quando
# SPX_VIGENCY_SYNC_ENABLED=1.
# SPX_VIGENCY_SYNC_ENABLED=0

# ── SPX alocação ASPX (atribuir motorista a viagem line_haul no portal Shopee) ─
# O backend fala com o sidecar spx-bot (bots/spx, :8766) na rede docker.
# SPX_SIDECAR_URL: em prod = http://spx-bot:8766 (nome do serviço no compose).
#   Sem isso o default é http://localhost:8766 (NÃO funciona dentro do container).
# SPX_ALLOC_WRITE_ENABLED: kill-switch do ENVIO REAL. Desligado (dry_run) por
#   padrão — o sidecar monta o body e NÃO toca o ASPX. Ligar só quando for atribuir
#   de verdade no portal Shopee.
# SPX_ALLOC_STATION_ID / SPX_ALLOC_AGENCY_ID: estação/agência do operador Lamonica
#   (defaults 5015 / 1297).
# SPX_SIDECAR_URL=http://spx-bot:8766
# SPX_ALLOC_WRITE_ENABLED=false
# SPX_ALLOC_STATION_ID=5015
# SPX_ALLOC_AGENCY_ID=1297

# ── Geoapify (geocoding / routing) ───────────────────────────────────────────
# If not set, routing features throw ConfigurationError at call time.
GEOAPIFY_API_KEY=

# ── Google Sheets (Shopee sync via /api/sync-sheet-loads) ────────────────────
# Sheet ID from the Google Sheets URL: .../d/<SHEET_ID>/edit
# OPTIONAL — endpoint returns 401 if CRON_SECRET not set; sheet ID needed to sync.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_GID=0

# Nome EXATO da aba que mapeia Motorista -> Vínculo (AGREGADO DEDICADO / PME /
# FROTA / PX), exibido ao lado do nome na fila do operador. Default: "Vinculo"
# (sem acento — coexiste com a aba "Vínculo" de dashboard; o nome exato evita a
# colisão). Sincronizada junto com o sheet sync de cargas.
GOOGLE_SHEET_VINCULO_TAB=Vinculo

# ── Checklist de veículos (LiraLOG via planilha do robô GRIFFI) ──────────────
# Aba VIVA "ChecklistViaAPI" (gid 1616923863) que o robô GRIFFI sincroniza do
# LiraLOG. Alimenta o card de status do veículo (cavalo/carreta) no Monitor.
# O semáforo é calculado ao vivo (validade x agora) → nunca fica atrasado.
# NÃO usar a aba "CHECKLIST" (primeira/default) — está CONGELADA desde ~mai/2026.
# Lemos por GID (export CSV): gid errado falha alto, em vez do fallback silencioso
# do gviz-por-nome para a primeira aba.
VEHICLE_CHECKLIST_ENABLED=true
# ID da planilha (default embutido = planilha do robô GRIFFI). Sobrescreva se mudar.
VEHICLE_CHECKLIST_SHEET_ID=
# gid da aba viva (default embutido = ChecklistViaAPI). Sobrescreva se o gid mudar.
VEHICLE_CHECKLIST_SHEET_GID=
# Só usado se GID vazio (lê por nome via gviz — menos robusto).
VEHICLE_CHECKLIST_SHEET_NAME=ChecklistViaAPI
# Janela do "amarelo" (dias antes de vencer). Default 30.
VEHICLE_CHECKLIST_YELLOW_DAYS=30

# Nome do cliente em `public.clientes.nome` que recebe as cargas vindas da
# planilha. DEVE bater EXATO (case-sensitive, sem trim adicional) com uma linha
# existente em clientes — senão o sync trava com SHEET_CLIENT_NOT_CONFIGURED.
#
# Em produção (2026-05-18) o cliente foi renomeado de "Shopee" para "E-COMMERCE"
# e isto causou 4 dias de sync offline porque o env var não estava sincronizado.
# Se renomear o cliente no DB, lembrar de atualizar essa variável também.
#
# Default no código (se unset): "Shopee".
GOOGLE_SHEET_DEFAULT_CLIENT_NAME=Shopee

# ── Segunda fonte de planilha: Nestlé (multi-sheet sync) ─────────────────────
# O sync agora puxa cargas de MÚLTIPLAS planilhas. A Nestlé é uma fonte extra,
# isolada da Shopee via cargas.sheet_source (um sync nunca expira as cargas da
# outra fonte). Regra de "disponível" idêntica: STATUS vazio + MOTORISTA vazio.
#
# URL de export CSV da planilha da Nestlé. Se unset, usa o default hardcodado no
# código (a planilha atual da Nestlé). Formato: .../d/<ID>/export?format=csv&gid=<GID>
GOOGLE_SHEET_NESTLE_URL=
# Nome do cliente em `public.clientes.nome` que recebe as cargas da Nestlé. DEVE
# bater EXATO (case/acento-sensitive) com uma linha de clientes. Em STAGING o
# cliente está grafado "Nestle" (SEM acento) → setar GOOGLE_SHEET_NESTLE_CLIENT_NAME=Nestle.
# Default no código (se unset): "Nestlé" (com acento, produção).
GOOGLE_SHEET_NESTLE_CLIENT_NAME=Nestlé

# Shared secret for the /api/sync-sheet-loads cron endpoint (Bearer token).
# If not set, the endpoint always returns 401 (fail-closed).
# OPTIONAL — only needed if using external cron scheduler.
CRON_SECRET=

# ── ASPX sync (CSV directory via GitHub Actions trigger) ─────────────────────
# GitHub Personal Access Token with `actions:write` scope on GITHUB_REPO.
# If not set, ASPX sync endpoint returns an error.
# OPTIONAL — only needed if ASPX sync feature is in use.
GITHUB_TOKEN=
# GITHUB_OWNER=grupolamonica
# GITHUB_REPO=aspx-sync
# GITHUB_ASPX_SYNC_WORKFLOW=sync.yml
# GITHUB_ASPX_SYNC_REF=main

# ── WhatsApp public leads ─────────────────────────────────────────────────────
# Full E.164 number (digits only). Example: 5571999999999
# If not set, WhatsApp redirect feature is disabled for public load claims.
# OPTIONAL
PUBLIC_LOAD_WHATSAPP_NUMBER=

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS — Optional runtime toggles.
# ═══════════════════════════════════════════════════════════════════════════════

# Load claim v2 state machine and waitlist.
# CLAIM_V2_ENABLED=true
# WAITLIST_ENABLED=true
# RESERVATION_TTL_SECONDS=120
# CLAIM_IDEMPOTENCY_TTL_SECONDS=86400
# CLAIM_MAINTENANCE_BATCH_SIZE=25

# PII redaction for public leads.
# PUBLIC_LEAD_PII_RETENTION_DAYS=30
# PUBLIC_LEAD_PII_REDACTION_BATCH_SIZE=100

# Driver loads sheet cache tuning (milliseconds).
# PUBLIC_DRIVER_LOADS_SHEET_STALE_AFTER_MS=420000
# PUBLIC_DRIVER_LOADS_SHEET_CHECK_COOLDOWN_MS=45000

# Recurring cargas — auto-advance job (carga recorrente).
# Job in-process (setInterval) que avança a data das cargas recorrentes OPEN
# para a próxima ocorrência, mantendo-as na fila sem o operador recriar.
# Ligado por padrão (single-replica). Em deploy MULTI-REPLICA, setar
# RECURRING_CARGO_ADVANCE_INLINE=false em todas as réplicas e disparar
# POST /api/cargas/advance-recurring via cron externo ÚNICO (autenticado com o
# mesmo CRON_SECRET do sheet-sync) para evitar varredura redundante.
# RECURRING_CARGO_ADVANCE_INLINE=true
# RECURRING_CARGO_ADVANCE_INTERVAL_MIN=5

# ═══════════════════════════════════════════════════════════════════════════════
# SSL / TLS for direct Postgres connection (usually not needed)
# ═══════════════════════════════════════════════════════════════════════════════
# Supabase Postgres connection strings already include SSL params via the URL.
# These vars are only needed when connecting to a self-hosted Postgres with a
# custom CA certificate or when you need to disable certificate verification.
#
# CLAIMS_DB_SSL_REJECT_UNAUTHORIZED=true
# CLAIMS_DB_SSL_CA_PATH=/path/to/ca.pem
# CLAIMS_DB_SSL_CA_B64=<base64-encoded PEM>
# CLAIMS_DB_SSL_CA_CERT=<raw PEM string with \n for newlines>
# (Configure only ONE of the three CA options — conflicts throw at startup.)

# ── Postgres pool size (optional) ─────────────────────────────────────────────
# Maximum number of pg pool connections. Default: 3
# CLAIMS_DB_POOL_MAX=3
