{
  "name": "lamonica-cargas-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/main.js",
    "dev:clone": "node --env-file=.env.dev src/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rls": "vitest run src/security/rls.behavior.test.js",
    "claims:maintenance": "node src/scripts/process-expired-load-claims.mjs",
    "sheet-sync": "node src/scripts/sync-sheet-loads.mjs",
    "routes:import-standard": "node src/scripts/import-standard-route-catalog.mjs",
    "security:rollout-check": "node src/scripts/security-rollout-check.mjs",
    "release:check": "node src/scripts/release-readiness-check.mjs",
    "supabase:setup": "node src/scripts/configure-supabase-project.mjs",
    "supabase:create-operator": "node src/scripts/create-initial-operator.mjs",
    "supabase:verify-login": "node src/scripts/verify-auth-login.mjs",
    "bench": "vitest bench --config benchmarks/vitest.bench.config.ts",
    "bench:db": "vitest bench --config benchmarks/vitest.bench.config.ts benchmarks/db/",
    "bench:app": "vitest bench --config benchmarks/vitest.bench.config.ts benchmarks/app/",
    "bench:perf": "vitest run --config benchmarks/vitest.bench.config.ts benchmarks/db/pool-contention.bench.js benchmarks/app/queue-rebalance.bench.js benchmarks/app/route-cascade.bench.js",
    "bench:http": "node benchmarks/http/load-endpoints.bench.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "date-fns": "^3.6.0",
    "express": "^4.22.1",
    "ioredis": "^5.10.1",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "autocannon": "^8.0.0",
    "pg-mem": "^3.0.14",
    "tinybench": "^6.0.1",
    "vitest": "^3.2.4"
  }
}
