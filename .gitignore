# GSD planning docs (local-only in multi-repo workspace)
.planning/

# Per-module node_modules and dist
frontend/node_modules/
frontend/dist/
backend/node_modules/
backend/dist/

# Python scripts
scripts/.venv/
scripts/**/__pycache__/
scripts/**/*.pyc

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment files — NEVER commit credentials
.env
.env.*
!.env.example
backend.env
backend/.env
frontend/.env

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local artifacts (never commit)
prod_schema.sql
*.dump
backup-pre-migration-*.json
data-dump-*.json
.bg-shell/
.claude/worktrees/

# Claude Code local settings (may contain secrets in tool allowlist)
.claude/settings.local.json

# User uploads (cadastro-motorista local OCR)
**/anexos_tmp/

# Local OCR test fixtures (real PDFs / selfies / CRLV / CNH used during dev).
# Must NEVER be committed: they are served from /public, would leak PII,
# and would inflate the production bundle. Move them to frontend/test/fixtures/
# if they need to be versioned anonymously.
frontend/public/test-fixtures/

# Split branches workspace (local-only commit-splitting notes)
.split-branches/

# Local generated docs / reports (per-developer)
docs/reports/
