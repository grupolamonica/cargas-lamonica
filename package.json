{
  "name": "lamonica-cargas-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm --prefix backend run start\" \"npm --prefix frontend run dev\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run start",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "npm --prefix backend run test",
    "test": "npm run test:frontend && npm run test:backend",
    "test:e2e:cargas-casadas": "playwright test --config=playwright.config.ts --reporter=list --workers=1",
    "test:e2e:cargas-casadas:list": "playwright test --config=playwright.config.ts --list",
    "install:all": "npm --prefix frontend install && npm --prefix backend install"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.1.2",
    "pg": "^8.21.0",
    "typescript": "^5.9.3"
  }
}
