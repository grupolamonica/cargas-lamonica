# Frontend environment variables
# Copy to .env.local and fill in the values

# Supabase credentials (frontend public keys only)
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# Backend API base URL for local development
# When empty, requests go to /api/* (same-origin — Vercel-compatible)
# When set, requests go to http://localhost:3001/api/* (local backend)
VITE_API_BASE_URL=http://localhost:3001

# Canonical origin for production redirects
VITE_CANONICAL_ORIGIN=""

# Route info API URL (optional, for production override)
VITE_ROUTE_INFO_API_URL=""
