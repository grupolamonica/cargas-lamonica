# frontend/.env.example
# Build-time variables injected as Docker ARGs during `docker compose build`.
# These become baked into the static Vite bundle — NOT available at runtime.
#
# Usage:
#   docker compose build \
#     --build-arg VITE_SUPABASE_URL=https://xxxx.supabase.co \
#     --build-arg VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
#
# For local dev (without Docker): copy to frontend/.env.local and fill in values.
# Vite loads .env.local automatically during `npm run dev`.

# ── Supabase (frontend public keys) ──────────────────────────────────────────
# Supabase project URL. Format: https://<project-ref>.supabase.co
# REQUIRED for auth and realtime features.
VITE_SUPABASE_URL=

# Supabase anon/public key — safe to expose in frontend bundle.
# Found in: Supabase Dashboard → Project Settings → API → anon public
# NOTE: the codebase uses VITE_SUPABASE_PUBLISHABLE_KEY (not VITE_SUPABASE_ANON_KEY)
# REQUIRED for Supabase client initialization.
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── API routing ───────────────────────────────────────────────────────────────
# Base URL for backend API calls. Leave empty for same-origin /api/* routing.
#
# Empty (default): requests go to /api/* relative to the frontend origin.
#   - In production (Docker + Traefik): Traefik routes /api/* to backend container.
#   - In local dev (npm run dev): vite.config.ts proxy routes /api/* to localhost:3001.
#
# Set to full URL only when frontend and backend are on different origins:
#   VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=
