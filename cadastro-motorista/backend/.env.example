INFOSIMPLES_TOKEN=COLE_SEU_TOKEN_AQUI

# ── OCR Sidecar Auth ─────────────────────────────────────────────────────────
# Token estatico compartilhado entre backend Node e sidecar Python. Vazio em
# dev local; obrigatorio em prod (header X-OCR-Sidecar-Token).
OCR_SIDECAR_TOKEN=

# ── OCR Strategies (Fase 2 da migracao OCR — 2026-05-21) ────────────────────
# Cada endpoint tem strategy configuravel:
#   legacy                              = comportamento antigo (so Infosimples
#                                         apos a Fase 3; nao ha mais EasyOCR)
#   infosimples-with-vision-fallback    = tenta primario; se code!=200, Vision
#   vision-only                         = chama GPT-4o Vision direto

OCR_CNH_STRATEGY=legacy
OCR_CRLV_STRATEGY=legacy
OCR_CARTAO_CNPJ_STRATEGY=legacy
OCR_RNTRC_STRATEGY=vision-only
OCR_COMPROVANTE_STRATEGY=legacy
OCR_SELFIE_CNH_STRATEGY=vision-only

# ── GPT-4o Vision (Fase 1+2 da migracao OCR — 2026-05-21) ────────────────────
# NUNCA commitar com valor real. Rotacionar imediatamente se vazar.
# Cobranca por uso (~$0.01-0.03/imagem). Vazio = Vision indisponivel.
OPENAI_API_KEY=

# Modelo Vision. "gpt-4o" = qualidade alta. "gpt-4o-mini" = ~10x mais barato
# mas perde acuracia em CNH/CRLV brasileiros. Default: gpt-4o.
GPT4O_VISION_MODEL=gpt-4o

# Timeout em segundos para chamadas Vision.
GPT4O_VISION_TIMEOUT_SECONDS=30

# Retries em RateLimitError/APITimeoutError.
GPT4O_VISION_MAX_RETRIES=2

# Orcamento diario USD. Reset diario UTC. Default 25.0 cobre ~12x volume
# previsto (~$2/dia = 500 cadastros/mes x 6 docs x ~$0.02).
GPT4O_DAILY_BUDGET_USD=25.0

# ── LGPD Cleanup ─────────────────────────────────────────────────────────────
# Anexos em /app/backend/anexos_tmp/ removidos apos TTL.
OCR_ATTACHMENT_TTL_HOURS=24
OCR_CLEANUP_INTERVAL_SECONDS=900

# ── Debug (DEV ONLY — nao habilitar em prod) ─────────────────────────────────
# true = expoe texto bruto extraido em respostas (vaza PII em logs).
OCR_RETURN_RAW_TEXT=false
